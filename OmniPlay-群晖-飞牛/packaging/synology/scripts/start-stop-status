#!/bin/sh

PACKAGE="OmniPlay"
APP_DIR="/var/packages/${PACKAGE}/target"
APP_ROOT="/var/packages/${PACKAGE}/home"
PID_FILE="${APP_ROOT}/omniplay.pid"
LOCK_DIR="${APP_ROOT}/omniplay.start.lock"
LOG_FILE="${APP_ROOT}/logs/server.log"
PORT="${SYNOPKG_PKGPORT:-${OMNIPLAY_PORT:-45721}}"
URLS="${OMNIPLAY_URLS:-}"
EXECUTABLE="${APP_DIR}/OmniPlay.Api"
MEDIA_TOOLS_ENV="${APP_ROOT}/settings/media-tools.env"
ENABLE_QSV="${OMNIPLAY_ENABLE_QSV:-0}"
LOG_MAX_BYTES="${OMNIPLAY_LOG_MAX_BYTES:-10485760}"
LOG_MAX_FILES="${OMNIPLAY_LOG_MAX_FILES:-5}"

find_media_tool() {
  TOOL_NAME="$1"
  for CANDIDATE in \
    "${APP_DIR}/bin/${TOOL_NAME}" \
    "${APP_DIR}/tools/ffmpeg/bin/${TOOL_NAME}" \
    "/var/packages/ffmpeg7/target/bin/${TOOL_NAME}" \
    "/var/packages/ffmpeg6/target/bin/${TOOL_NAME}" \
    "/var/packages/ffmpeg5/target/bin/${TOOL_NAME}" \
    "/var/packages/ffmpeg4/target/bin/${TOOL_NAME}" \
    "/var/packages/ffmpeg/target/bin/${TOOL_NAME}" \
    "/var/packages/jellyfin-ffmpeg/target/bin/${TOOL_NAME}" \
    "/var/packages/Jellyfin/target/bin/${TOOL_NAME}" \
    "/var/packages/CodecPack/target/bin/${TOOL_NAME}" \
    "/var/packages/VideoStation/target/bin/${TOOL_NAME}" \
    "/var/packages/MediaServer/target/bin/${TOOL_NAME}" \
    "/var/packages/AdvancedMediaExtensions/target/bin/${TOOL_NAME}" \
    "/var/packages/CodecPack/target/bin/${TOOL_NAME}41" \
    "/var/packages/VideoStation/target/bin/${TOOL_NAME}41" \
    "/usr/local/bin/${TOOL_NAME}" \
    "/usr/syno/bin/${TOOL_NAME}" \
    "/usr/bin/${TOOL_NAME}" \
    "/bin/${TOOL_NAME}"
  do
    if [ -x "${CANDIDATE}" ]; then
      printf '%s\n' "${CANDIDATE}"
      return 0
    fi
  done

  if [ "${TOOL_NAME}" = "ffmpeg" ] && [ -x "/usr/syno/bin/synoffmpeg" ]; then
    printf '%s\n' "/usr/syno/bin/synoffmpeg"
    return 0
  fi

  printf '%s\n' "${TOOL_NAME}"
}

find_vaapi_device() {
  if [ -n "${OMNIPLAY_VAAPI_DEVICE:-}" ]; then
    printf '%s\n' "${OMNIPLAY_VAAPI_DEVICE}"
    return 0
  fi

  for CANDIDATE in /dev/dri/renderD*; do
    if [ -e "${CANDIDATE}" ]; then
      printf '%s\n' "${CANDIDATE}"
      return 0
    fi
  done

  printf '%s\n' "/dev/dri/renderD128"
}

prepend_library_path_for_tool() {
  TOOL_PATH="$1"
  case "${TOOL_PATH}" in
    /*/bin/*)
      TOOL_ROOT="$(cd "$(dirname "${TOOL_PATH}")/.." 2>/dev/null && pwd)"
      if [ -n "${TOOL_ROOT}" ]; then
        for LIB_DIR in "${TOOL_ROOT}/lib" "${TOOL_ROOT}/lib64"; do
          if [ -d "${LIB_DIR}" ]; then
            prepend_library_path "${LIB_DIR}"
            prepend_onevpl_search_path "${LIB_DIR}"
            prepend_libva_driver_path "${LIB_DIR}/dri"
            prepend_library_path "${LIB_DIR}/mfx"
            prepend_onevpl_search_path "${LIB_DIR}/mfx"
          fi
        done
      fi
      ;;
  esac
}

prepend_library_path() {
  LIB_DIR="$1"
  if [ ! -d "${LIB_DIR}" ]; then
    return 0
  fi

  case ":${LD_LIBRARY_PATH:-}:" in
    *":${LIB_DIR}:"*) ;;
    *) LD_LIBRARY_PATH="${LIB_DIR}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}" ;;
  esac
}

prepend_libva_driver_path() {
  DRIVER_DIR="$1"
  if [ ! -d "${DRIVER_DIR}" ]; then
    return 0
  fi

  case ":${LIBVA_DRIVERS_PATH:-}:" in
    *":${DRIVER_DIR}:"*) ;;
    *) LIBVA_DRIVERS_PATH="${DRIVER_DIR}${LIBVA_DRIVERS_PATH:+:${LIBVA_DRIVERS_PATH}}" ;;
  esac
}

prepend_onevpl_search_path() {
  case "${ENABLE_QSV}" in
    1|yes|true|on) ;;
    *) return 0 ;;
  esac

  SEARCH_DIR="$1"
  if [ ! -d "${SEARCH_DIR}" ]; then
    return 0
  fi

  case ":${ONEVPL_SEARCH_PATH:-}:" in
    *":${SEARCH_DIR}:"*) ;;
    *) ONEVPL_SEARCH_PATH="${SEARCH_DIR}${ONEVPL_SEARCH_PATH:+:${ONEVPL_SEARCH_PATH}}" ;;
  esac
}

append_libva_driver_path_once() {
  DRIVER_DIR="$1"
  if [ ! -d "${DRIVER_DIR}" ]; then
    return 0
  fi

  case ":${LIBVA_DRIVERS_PATH:-}:" in
    *":${DRIVER_DIR}:"*) ;;
    *) LIBVA_DRIVERS_PATH="${LIBVA_DRIVERS_PATH:+${LIBVA_DRIVERS_PATH}:}${DRIVER_DIR}" ;;
  esac
}

append_libva_driver_path() {
  for DRIVER_DIR in \
    "/var/packages/jellyfin-ffmpeg/target/lib/dri" \
    "/var/packages/Jellyfin/target/lib/jellyfin-ffmpeg/lib/dri" \
    "/usr/lib/jellyfin-ffmpeg/lib/dri" \
    "/usr/lib/x86_64-linux-gnu/dri" \
    "/usr/lib/dri" \
    "/usr/lib64/dri" \
    "/usr/local/lib/dri" \
    "/lib/dri" \
    "/var/packages/CodecPack/target/lib/dri" \
    "/var/packages/AdvancedMediaExtensions/target/lib/dri" \
    "/var/packages/VideoStation/target/lib/dri"
  do
    append_libva_driver_path_once "${DRIVER_DIR}"
  done
}

find_libva_driver_name() {
  OLD_IFS="${IFS}"
  IFS=":"
  for DRIVER_DIR in ${LIBVA_DRIVERS_PATH:-}; do
    for DRIVER_NAME in iHD i965 radeonsi nouveau; do
      if [ -f "${DRIVER_DIR}/${DRIVER_NAME}_drv_video.so" ]; then
        IFS="${OLD_IFS}"
        printf '%s\n' "${DRIVER_NAME}"
        return 0
      fi
    done
  done
  IFS="${OLD_IFS}"
  return 1
}

find_running_pids() {
  (ps w 2>/dev/null || ps 2>/dev/null) | grep '[O]mniPlay.Api' | awk '{ print $1 }'
}

pid_is_running() {
  PID="$1"
  case "${PID}" in
    ''|*[!0-9]*) return 1 ;;
  esac
  kill -0 "${PID}" 2>/dev/null
}

pid_file_is_running() {
  if [ ! -f "${PID_FILE}" ]; then
    return 1
  fi

  PID="$(sed -n '1p' "${PID_FILE}" 2>/dev/null || true)"
  pid_is_running "${PID}"
}

first_running_pid() {
  for PID in $(find_running_pids); do
    if pid_is_running "${PID}"; then
      printf '%s\n' "${PID}"
      return 0
    fi
  done

  return 1
}

remember_existing_process() {
  PID="$(first_running_pid || true)"
  if [ -n "${PID}" ]; then
    mkdir -p "${APP_ROOT}/data" "${APP_ROOT}/cache" "${APP_ROOT}/logs" "${APP_ROOT}/settings"
    printf '%s\n' "${PID}" > "${PID_FILE}"
    return 0
  fi

  return 1
}

append_pid_once() {
  PID="$1"
  case " ${STOP_PIDS} " in
    *" ${PID} "*) ;;
    *) STOP_PIDS="${STOP_PIDS}${STOP_PIDS:+ }${PID}" ;;
  esac
}

rotate_log_file() {
  case "${LOG_MAX_BYTES}" in
    ''|*[!0-9]*) LOG_MAX_BYTES=10485760 ;;
  esac
  case "${LOG_MAX_FILES}" in
    ''|*[!0-9]*) LOG_MAX_FILES=5 ;;
  esac

  if [ "${LOG_MAX_FILES}" -lt 2 ] || [ ! -f "${LOG_FILE}" ]; then
    return 0
  fi

  CURRENT_SIZE="$(wc -c < "${LOG_FILE}" 2>/dev/null | awk '{ print $1 }')"
  case "${CURRENT_SIZE}" in
    ''|*[!0-9]*) return 0 ;;
  esac

  if [ "${CURRENT_SIZE}" -lt "${LOG_MAX_BYTES}" ]; then
    return 0
  fi

  rm -f "${LOG_FILE}.${LOG_MAX_FILES}" 2>/dev/null || true
  INDEX=$((LOG_MAX_FILES - 1))
  while [ "${INDEX}" -ge 1 ]; do
    NEXT=$((INDEX + 1))
    if [ -f "${LOG_FILE}.${INDEX}" ]; then
      mv "${LOG_FILE}.${INDEX}" "${LOG_FILE}.${NEXT}" 2>/dev/null || true
    fi
    INDEX=$((INDEX - 1))
  done

  mv "${LOG_FILE}" "${LOG_FILE}.1" 2>/dev/null || true
  : > "${LOG_FILE}" 2>/dev/null || true
}

wait_for_startup() {
  START_PID="$1"
  WAIT_COUNT=0
  while [ "${WAIT_COUNT}" -lt 20 ]; do
    if pid_is_running "${START_PID}"; then
      return 0
    fi
    if remember_existing_process; then
      return 0
    fi
    WAIT_COUNT=$((WAIT_COUNT + 1))
    sleep 1
  done

  return 1
}

acquire_start_lock() {
  mkdir -p "${APP_ROOT}/settings" "${APP_ROOT}/logs"
  WAIT_COUNT=0
  while ! mkdir "${LOCK_DIR}" 2>/dev/null; do
    WAIT_COUNT=$((WAIT_COUNT + 1))
    if [ "${WAIT_COUNT}" -ge 30 ]; then
      rm -rf "${LOCK_DIR}" 2>/dev/null || true
      WAIT_COUNT=0
    fi
    sleep 1
  done
  trap 'rm -rf "${LOCK_DIR}" 2>/dev/null || true' EXIT INT TERM
}

port_is_listening() {
  PORT_TO_CHECK="$1"

  if command -v netstat >/dev/null 2>&1; then
    if netstat -lnt 2>/dev/null | awk -v port=":${PORT_TO_CHECK}" '$4 ~ port "$" { found = 1 } END { exit found ? 0 : 1 }'; then
      return 0
    fi
  fi

  PORT_HEX="$(printf '%04X' "${PORT_TO_CHECK}" 2>/dev/null || true)"
  if [ -n "${PORT_HEX}" ]; then
    if awk -v port=":${PORT_HEX}" '$2 ~ port "$" && $4 == "0A" { found = 1 } END { exit found ? 0 : 1 }' /proc/net/tcp /proc/net/tcp6 2>/dev/null; then
      return 0
    fi
  fi

  return 1
}

choose_listen_port() {
  REQUESTED_PORT="$1"
  if ! port_is_listening "${REQUESTED_PORT}"; then
    printf '%s\n' "${REQUESTED_PORT}"
    return 0
  fi

  for CANDIDATE_PORT in 45722 45723 45724 45725 45726 45727 45728 45729 45730 45731 45732 45733 45734 45735 45736 45737 45738 45739 45740; do
    if ! port_is_listening "${CANDIDATE_PORT}"; then
      printf '%s\n' "${CANDIDATE_PORT}"
      return 0
    fi
  done

  printf '%s\n' "${REQUESTED_PORT}"
  return 1
}

start() {
  acquire_start_lock

  mkdir -p "${APP_ROOT}/data" "${APP_ROOT}/cache" "${APP_ROOT}/logs" "${APP_ROOT}/settings"
  rotate_log_file
  if pid_file_is_running; then
    exit 0
  fi
  rm -f "${PID_FILE}"

  if remember_existing_process; then
    exit 0
  fi

  if [ ! -x "${EXECUTABLE}" ]; then
    echo "Missing executable: ${EXECUTABLE}" >> "${LOG_FILE}"
    exit 1
  fi

  if [ -f "${MEDIA_TOOLS_ENV}" ]; then
    # shellcheck disable=SC1090
    . "${MEDIA_TOOLS_ENV}"
    ENABLE_QSV="${OMNIPLAY_ENABLE_QSV:-${ENABLE_QSV}}"
  fi

  if [ -z "${URLS}" ]; then
    SELECTED_PORT="$(choose_listen_port "${PORT}")" || {
      echo "No available OmniPlay listen port found near ${PORT}." >> "${LOG_FILE}"
      exit 1
    }
    if [ "${SELECTED_PORT}" != "${PORT}" ]; then
      echo "Requested port ${PORT} is already in use; using ${SELECTED_PORT} for this start." >> "${LOG_FILE}"
      PORT="${SELECTED_PORT}"
    fi
    URLS="http://0.0.0.0:${PORT}"
  fi
  printf '%s\n' "${PORT}" > "${APP_ROOT}/settings/listen-port"

  OMNIPLAY_FFMPEG_PATH="${OMNIPLAY_FFMPEG_PATH:-$(find_media_tool ffmpeg)}"
  OMNIPLAY_FFPROBE_PATH="${OMNIPLAY_FFPROBE_PATH:-$(find_media_tool ffprobe)}"
  OMNIPLAY_VAAPI_DEVICE="${OMNIPLAY_VAAPI_DEVICE:-$(find_vaapi_device)}"
  FONTCONFIG_FILE="${FONTCONFIG_FILE:-${APP_DIR}/tools/fontconfig/fonts.conf}"
  FONTCONFIG_PATH="${FONTCONFIG_PATH:-${APP_DIR}/tools/fontconfig}"
  FONTCONFIG_CACHE="${FONTCONFIG_CACHE:-${APP_ROOT}/cache/fontconfig}"
  mkdir -p "${FONTCONFIG_CACHE}"
  prepend_library_path_for_tool "${OMNIPLAY_FFMPEG_PATH}"
  prepend_library_path_for_tool "${OMNIPLAY_FFPROBE_PATH}"
  append_libva_driver_path
  DETECTED_LIBVA_DRIVER_NAME="$(find_libva_driver_name || true)"

  {
    echo "Using FFmpeg: ${OMNIPLAY_FFMPEG_PATH}"
    echo "Using FFprobe: ${OMNIPLAY_FFPROBE_PATH}"
    echo "Using VAAPI device: ${OMNIPLAY_VAAPI_DEVICE}"
    [ -n "${LIBVA_DRIVERS_PATH:-}" ] && echo "Using LIBVA drivers: ${LIBVA_DRIVERS_PATH}"
    [ -n "${LIBVA_DRIVER_NAME:-}" ] && echo "Using forced LIBVA driver: ${LIBVA_DRIVER_NAME}"
    [ -z "${LIBVA_DRIVER_NAME:-}" ] && [ -n "${DETECTED_LIBVA_DRIVER_NAME:-}" ] && echo "Detected LIBVA driver candidate: ${DETECTED_LIBVA_DRIVER_NAME}; leaving LIBVA_DRIVER_NAME unset for auto selection"
    [ -n "${ONEVPL_SEARCH_PATH:-}" ] && echo "Using oneVPL search path: ${ONEVPL_SEARCH_PATH}"
    [ -f "${FONTCONFIG_FILE}" ] && echo "Using fontconfig: ${FONTCONFIG_FILE}"
  } >> "${LOG_FILE}"

  export OMNIPLAY_APP_ROOT="${APP_ROOT}"
  export OMNIPLAY_PORT="${PORT}"
  export OMNIPLAY_URLS="${URLS}"
  export OMNIPLAY_FFMPEG_PATH="${OMNIPLAY_FFMPEG_PATH}"
  export OMNIPLAY_FFPROBE_PATH="${OMNIPLAY_FFPROBE_PATH}"
  export OMNIPLAY_VAAPI_DEVICE="${OMNIPLAY_VAAPI_DEVICE}"
  export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:-}"
  [ -f "${FONTCONFIG_FILE}" ] && export FONTCONFIG_FILE
  [ -d "${FONTCONFIG_PATH}" ] && export FONTCONFIG_PATH
  export FONTCONFIG_CACHE
  [ -n "${ONEVPL_SEARCH_PATH:-}" ] && export ONEVPL_SEARCH_PATH
  [ -n "${LIBVA_DRIVERS_PATH:-}" ] && export LIBVA_DRIVERS_PATH
  [ -n "${LIBVA_DRIVER_NAME:-}" ] && export LIBVA_DRIVER_NAME
  nohup "${EXECUTABLE}" >> "${LOG_FILE}" 2>&1 &
  START_PID="$!"
  echo "${START_PID}" > "${PID_FILE}"
  if wait_for_startup "${START_PID}"; then
    exit 0
  fi

  echo "OmniPlay.Api exited during startup; pid=${START_PID}." >> "${LOG_FILE}"
  if ! pid_file_is_running; then
    rm -f "${PID_FILE}"
  fi
  exit 1
}

stop() {
  STOP_PIDS=""

  if [ -f "${PID_FILE}" ]; then
    PID="$(sed -n '1p' "${PID_FILE}" 2>/dev/null || true)"
    if pid_is_running "${PID}"; then
      append_pid_once "${PID}"
    fi
  fi

  for PID in $(find_running_pids); do
    if pid_is_running "${PID}"; then
      append_pid_once "${PID}"
    fi
  done

  for PID in ${STOP_PIDS}; do
    kill "${PID}" 2>/dev/null || true
    WAIT_COUNT=0
    while kill -0 "${PID}" 2>/dev/null && [ "${WAIT_COUNT}" -lt 20 ]; do
      WAIT_COUNT=$((WAIT_COUNT + 1))
      sleep 1
    done
    if kill -0 "${PID}" 2>/dev/null; then
      kill -9 "${PID}" 2>/dev/null || true
    fi
  done

  rm -f "${PID_FILE}"
}

status() {
  if pid_file_is_running; then
    exit 0
  fi

  rm -f "${PID_FILE}"
  if remember_existing_process; then
    exit 0
  fi

  exit 3
}

case "$1" in
  prestart) exit 0 ;;
  prestop) exit 0 ;;
  start) start ;;
  stop) stop ;;
  restart) stop; start ;;
  status) status ;;
  log) tail -n 80 "${LOG_FILE}" ;;
  *) exit 1 ;;
esac
