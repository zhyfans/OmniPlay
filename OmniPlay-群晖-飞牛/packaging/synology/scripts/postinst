#!/bin/sh

PACKAGE="OmniPlay"
APP_DIR="/var/packages/${PACKAGE}/target"
APP_ROOT="/var/packages/${PACKAGE}/home"
LOG_FILE="/tmp/omniplay-postinst.log"

log() {
  printf '%s\n' "$*" >> "${LOG_FILE}" 2>/dev/null || true
}

: > "${LOG_FILE}" 2>/dev/null || true

grant_group_access() {
  GROUP_NAME="$1"
  if [ -z "${GROUP_NAME}" ] || [ "${GROUP_NAME}" = "root" ]; then
    return 1
  fi

  if id "${PACKAGE}" 2>/dev/null | grep -Eq "(^|[,(])${GROUP_NAME}([),]|$)"; then
    log "user ${PACKAGE} already has group ${GROUP_NAME}"
    return 0
  fi

  log "user ${PACKAGE} is not in ${GROUP_NAME}; trying command fallback"
  for SYNOGROUP in "$(command -v synogroup 2>/dev/null)" /usr/syno/sbin/synogroup /usr/syno/bin/synogroup; do
    if [ -n "${SYNOGROUP}" ] && [ -x "${SYNOGROUP}" ]; then
      log "trying ${SYNOGROUP} --memberadd ${GROUP_NAME} ${PACKAGE}"
      if "${SYNOGROUP}" --memberadd "${GROUP_NAME}" "${PACKAGE}" >> "${LOG_FILE}" 2>&1; then
        log "added ${PACKAGE} to ${GROUP_NAME} via ${SYNOGROUP} --memberadd"
        return 0
      fi
    fi
  done

  if command -v usermod >/dev/null 2>&1; then
    log "trying usermod -a -G ${GROUP_NAME} ${PACKAGE}"
    if usermod -a -G "${GROUP_NAME}" "${PACKAGE}" >> "${LOG_FILE}" 2>&1; then
      log "added ${PACKAGE} to ${GROUP_NAME} via usermod"
      return 0
    fi
  fi

  log "unable to add ${PACKAGE} to ${GROUP_NAME}"
  return 1
}

grant_dri_access() {
  log "postinst effective id: $(id 2>/dev/null || true)"
  if ! id "${PACKAGE}" >/dev/null 2>&1; then
    log "package user ${PACKAGE} does not exist yet"
    return 0
  fi
  log "package user id: $(id "${PACKAGE}" 2>/dev/null || true)"

  FOUND_DEVICE=0
  for DEVICE in /dev/dri/renderD*; do
    [ -e "${DEVICE}" ] || continue
    FOUND_DEVICE=1
    DEVICE_GROUP="$(ls -l "${DEVICE}" 2>/dev/null | awk '{ print $4 }')"
    log "detected ${DEVICE} group=${DEVICE_GROUP}"
    grant_group_access "${DEVICE_GROUP}" || true
  done
  if [ "${FOUND_DEVICE}" -eq 0 ]; then
    log "no /dev/dri/renderD* device found"
  fi
}

if [ ! -x "${APP_DIR}/OmniPlay.Api" ] && [ -x "${APP_DIR}/package/OmniPlay.Api" ]; then
  for ITEM in "${APP_DIR}/package"/* "${APP_DIR}/package"/.[!.]* "${APP_DIR}/package"/..?*; do
    [ -e "${ITEM}" ] || continue
    mv "${ITEM}" "${APP_DIR}/"
  done
  rmdir "${APP_DIR}/package" 2>/dev/null || true
fi

mkdir -p "${APP_ROOT}/data" "${APP_ROOT}/cache" "${APP_ROOT}/logs" "${APP_ROOT}/settings"

if [ -n "${SYNOPKG_PKGVER:-}" ]; then
  printf '%s\n' "${SYNOPKG_PKGVER}" > "${APP_ROOT}/settings/package-version"
fi

grant_dri_access

if [ -x "/var/packages/${PACKAGE}/scripts/start-stop-status" ]; then
  "/var/packages/${PACKAGE}/scripts/start-stop-status" start >/dev/null 2>&1 || true
fi

exit 0
